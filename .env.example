# ==============================================================================
# SPOKE-FOUNDRYVTT - MODULE ENVIRONMENT EXAMPLE
# ==============================================================================
# Description: Module-specific environment defaults for spoke-foundryvtt
# Version: 1.0.0
# ==============================================================================
# Copy to .env and adjust values for your deployment.
# Hub variables (TZ, DOMAIN, SPOKE_DIR, etc.) are injected by Spoke at runtime.
# ==============================================================================

#### IMAGE

FOUNDRYVTT_IMAGE=felddy/foundryvtt:13.351.0

#### NETWORK

FOUNDRYVTT_IP=192.168.35.25
FOUNDRYVTT_HOST=foundry.${DOMAIN}

#### DATA

# Path to FoundryVTT persistent data (worlds, systems, modules)
FOUNDRYVTT_DATA_DIR=${APPDATA_DIR}/foundryvtt/data
